# Cloudflare Pages applies these headers to served assets.

# HTML — short edge cache so a fresh build is picked up promptly,
# long stale-while-revalidate so users always get an instant page.
/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=604800

/index.html
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=604800

# Hashed Next.js assets are immutable.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Other static assets (favicons etc.) — cache hard, refresh weekly.
/*.ico
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/*.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Sensible default: enable a long edge cache + SWR everywhere else.
/*
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=604800
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
